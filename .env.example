# ============================================================
# Autonomous Bounty Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env or wallet.json to version control.
# ============================================================

# Synapse/OOBE Protocol API key
# Get yours at: https://synapse.oobeprotocol.ai
SYNAPSE_API_KEY=YOUR_SYNAPSE_API_KEY

# Solana RPC endpoint (OOBE Protocol mainnet or any Solana mainnet RPC)
# Required
SOLANA_RPC_URL=https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=YOUR_SYNAPSE_API_KEY

# Path to the Solana keypair JSON file (64-byte secret key array)
# Required — generate with: solana-keygen new --outfile wallet.json
WALLET_KEYPAIR_PATH=./wallet.json

# Ace Data Cloud API base URL
# Optional — defaults to https://api.acedata.cloud
ACEDATA_BASE_URL=https://api.acedata.cloud

# Ace Data Cloud API key
# Get yours at: https://platform.acedata.cloud (free credits on signup)
ACEDATA_API_KEY=YOUR_ACEDATA_API_KEY

# x402 payment facilitator URL for AceDataCloud
# Optional — defaults to https://facilitator.acedata.cloud
FACILITATOR_URL=https://facilitator.acedata.cloud

# USDC SPL token mint address on Solana mainnet
# Optional — defaults to EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# x402 settlement network
# Optional — defaults to solana
# Allowed values: solana | base
NETWORK=solana
